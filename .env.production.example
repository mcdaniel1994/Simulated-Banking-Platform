# Public single-origin hostname. DNS must resolve this name to the VPS before certificate issuance.
APP_DOMAIN=bank.example.com
HTTP_PORT=80
HTTPS_PORT=443

# Supabase Shared Pooler session-mode URL. Replace every placeholder and retain TLS.
DATABASE_URL=postgresql+psycopg://postgres.project-ref:replace-with-database-password@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require

# Generate a long random value directly on the deployment host; never commit the real value.
SESSION_SECRET=replace-with-a-long-random-production-secret
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=12

# Blank preserves a host-only __Host-session cookie. Production is same-origin, so CORS is empty.
COOKIE_DOMAIN=
CSRF_COOKIE_NAME=csrf_token

# Host paths mounted read-only into nginx. These files are provisioned outside this repository.
TLS_CERTIFICATE_PATH=/etc/letsencrypt/live/bank.example.com/fullchain.pem
TLS_PRIVATE_KEY_PATH=/etc/letsencrypt/live/bank.example.com/privkey.pem
