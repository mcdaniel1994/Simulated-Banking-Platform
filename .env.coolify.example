# Enter these values in Coolify's environment-variable interface; do not commit real values.

# Supabase Shared Pooler session-mode URL for the persistent FastAPI service, with TLS required.
DATABASE_URL=postgresql+psycopg://postgres.project-ref:replace-with-database-password@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require

# Generate a long random value and store it only as a masked Coolify secret.
SESSION_SECRET=replace-with-a-long-random-production-secret
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=12

# Blank preserves the host-only __Host-session cookie. Production is one origin with no CORS.
COOKIE_DOMAIN=
CSRF_COOKIE_NAME=csrf_token
