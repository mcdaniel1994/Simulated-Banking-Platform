# The image bootstrap administrator is container-internal; application code never uses this login.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-secure-postgres-admin-password
POSTGRES_DB=simulated_banking_dev

# Initialization creates this least-privilege owner for both banking databases.
BANKING_DB_USER=banking_user
BANKING_DB_PASSWORD=replace-with-secure-local-password

# Runtime code uses only the development URL; database tests require the separate test URL.
DATABASE_URL=postgresql+psycopg://banking_user:replace-with-secure-local-password@localhost:5433/simulated_banking_dev
TEST_DATABASE_URL=postgresql+psycopg://banking_user:replace-with-secure-local-password@localhost:5433/simulated_banking_test

# Replace this placeholder in the untracked .env file; never commit the real secret.
SESSION_SECRET=replace-with-a-long-random-local-development-secret

# D1 session-lifetime decision: 30 minutes idle, 12 hours absolute.
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=12

# Leave blank for local host-only cookies. Production configuration may supply a domain.
COOKIE_DOMAIN=

# Pydantic parses complex environment values as JSON.
CORS_ORIGINS=["http://localhost:5173"]

# Readable CSRF cookie name used by the future double-submit implementation.
CSRF_COOKIE_NAME=csrf_token

# Allowed values: development, test, production.
ENV=development
